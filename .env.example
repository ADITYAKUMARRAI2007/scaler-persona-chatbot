# Get a Gemini API key from Google AI Studio: https://aistudio.google.com/app/apikey
# Never commit your real key. Copy this file to .env.local and replace the placeholder.
GEMINI_API_KEY=your_gemini_api_key_here

# Optional. Defaults to gemini-2.5-flash-lite.
GEMINI_MODEL=gemini-2.5-flash-lite

# Optional. Tried only if the primary model is quota-limited or unavailable.
GEMINI_FALLBACK_MODELS=gemini-2.0-flash-lite,gemma-3-4b-it

# Optional but recommended for deployment login/database via Supabase Auth.
# Create a Supabase project, then paste Project URL + anon public key here.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
